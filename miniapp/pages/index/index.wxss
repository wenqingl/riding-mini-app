.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 登录页 */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.logo {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}
.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
}
.login-btn {
  width: 80%;
  background: #4A90D9;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
}
.hint {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 20rpx;
}

/* 主页面 */
.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}
.welcome {
  font-size: 30rpx;
  font-weight: bold;
}
.logout {
  font-size: 26rpx;
  color: #999;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
}
.selected-count {
  font-size: 26rpx;
  color: #4A90D9;
}

/* 记录列表 */
.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transition: background 0.2s;
}
.record-item.selected {
  background: #e6f3ff;
  border: 2rpx solid #4A90D9;
}
.checkbox {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 50rpx;
  text-align: center;
}
.record-info {
  flex: 1;
}
.record-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}
.record-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 操作按钮 */
.action-bar {
  margin-top: 30rpx;
}
.merge-btn {
  width: 100%;
  background: #4A90D9;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
}
.merge-btn[disabled] {
  background: #ccc;
}
.tip {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  margin-top: 20rpx;
}

/* 合并结果 */
.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  margin-top: 30rpx;
}
.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #52c41a;
  display: block;
  margin-bottom: 16rpx;
}
.result-meta {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}
.result-hint {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}
.result-hint.warn {
  color: #faad14;
}
.download-btn {
  background: #52c41a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 16rpx;
}
.reset-btn {
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
}

/* 空状态 & 加载 */
.empty, .loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 30rpx;
}
