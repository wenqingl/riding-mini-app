<view class="container">
  <!-- 未登录状态 -->
  <view wx:if="{{!loggedIn}}" class="login-section">
    <view class="logo">🚴</view>
    <text class="title">骑行数据合并</text>
    <text class="desc">合并你的分段骑行记录，告别付费合并</text>
    <button class="login-btn" bindtap="doLogin">
      <text class="btn-text">🔗 登录行者账号</text>
    </button>
    <text class="hint">需要行者账号授权才能使用</text>
  </view>

  <!-- 已登录状态 -->
  <view wx:if="{{loggedIn}}" class="main-section">
    <!-- 用户信息栏 -->
    <view class="user-bar">
      <text class="welcome">👋 {{userName}}</text>
      <text class="logout" bindtap="doLogout">退出</text>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <!-- 记录列表 -->
    <view wx:if="{{!loading && records.length > 0}}">
      <view class="section-header">
        <text class="section-title">📋 选择要合并的记录</text>
        <text class="selected-count" wx:if="{{selectedCount > 0}}">已选 {{selectedCount}} 条</text>
      </view>
      
      <view wx:for="{{records}}" wx:key="id" 
        class="record-item {{item.selected ? 'selected' : ''}}" 
        bindtap="toggleRecord" data-id="{{item.id}}">
        <view class="checkbox">
          <text wx:if="{{item.selected}}">☑</text>
          <text wx:else>☐</text>
        </view>
        <view class="record-info">
          <text class="record-name">{{item.name || '骑行记录'}}</text>
          <text class="record-meta">{{item.date}} | {{item.distance}}km | {{item.duration}}</text>
        </view>
      </view>

      <!-- 合并按钮 -->
      <view class="action-bar" wx:if="{{selectedCount >= 2}}">
        <button class="merge-btn" bindtap="doMerge" disabled="{{merging}}">
          {{merging ? '合并中...' : '🔄 合并 ' + selectedCount + ' 条记录'}}
        </button>
      </view>
      
      <view class="tip" wx:if="{{selectedCount < 2 && selectedCount > 0}}">
        <text>请至少选择 2 条记录</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && records.length === 0}}" class="empty">
      <text>📭 没有找到骑行记录</text>
    </view>

    <!-- 合并结果 -->
    <view wx:if="{{mergeResult}}" class="result-card">
      <text class="result-title">✅ 合并成功！</text>
      <text class="result-meta">共 {{mergeResult.total_points}} 个数据点</text>
      <text class="result-hint" wx:if="{{mergeResult.success}}">已自动上传至行者</text>
      <text class="result-hint warn" wx:else>上传失败，请手动下载</text>
      <button class="download-btn" bindtap="doDownload">📥 下载合并文件</button>
      <button class="reset-btn" bindtap="resetMerge">返回</button>
    </view>
  </view>
</view>
