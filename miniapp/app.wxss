.container { padding: 20rpx; }
.title { font-size: 36rpx; font-weight: bold; text-align: center; margin: 40rpx 0; }
.desc { color: #666; text-align: center; margin-bottom: 40rpx; }
.section-title { font-size: 30rpx; font-weight: bold; margin: 20rpx 0; }
.record-item { display: flex; align-items: center; padding: 20rpx; border-bottom: 1rpx solid #eee; }
.record-item.selected { background: #e6f3ff; }
.record-info { margin-left: 20rpx; }
.record-info text { display: block; color: #333; }
.result { text-align: center; margin-top: 30rpx; color: #52c41a; }
